{
  "name": "@infineon/infineon-icons",
  "version": "4.8.1",
  "private": false,
  "description": "Infineon Icons",
  "license": "MIT",
  "homepage": "https://github.com/Infineon/Infineon-Icons#readme",
  "bugs": {
    "url": "https://github.com/Infineon/Infineon-Icons/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Infineon/Infineon-Icons.git"
  },
  "author": "Kai Werther",
  "scripts": {
    "build": "npm run generate:js && npm run build:icons",
    "generate:js": "node ./build/generate.cjs",
    "build:icons": "rollup --config rollup.config.js"
  },
  "type": "module",
  "main": "dist/icons.js",
  "types": "dist/icons.d.ts",
  "exports": {
    ".": {
      "types": "./dist/icons.d.ts",
      "import": "./dist/icons.js",
      "require": "./dist/icons.js",
      "default": "./dist/icons.js"
    }
  },
  "files": [
    "dist",
    "svg"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.2",
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.0.1",
    "auto": "^10.37.4",
    "eslint": "^7.32.0",
    "eslint-config-airbnb-base": "^14.2.1",
    "fantasticon": "^4.1.0",
    "opentype.js": "^1.3.4",
    "rollup": "^2.79.1",
    "rollup-plugin-inline-svg": "^3.0.3",
    "rollup-plugin-string": "^3.0.0"
  },
  "pnpm": {
    "overrides": {
      "@xmldom/xmldom": ">=0.8.13",
      "xml2js": ">=0.5.0"
    }
  },
  "auto": {
    "plugins": [
      "npm",
      "released"
    ]
  }
}
